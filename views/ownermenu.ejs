<!DOCTYPE html>
<html>

<head>
    <%- include("partials/head") %>
    <title>Manage Menu</title>
</head>

<body>

<%- include("partials/ownernav") %>

<div class="container mt-5">

    <h1 class="mb-4">
        Manage Menu
    </h1>

    <!-- Buttons -->

    <div class="mb-4">

        <button
        class="btn btn-success me-2"
        onclick="showSection('addSection')">

            Add Item

        </button>

        <button
        class="btn btn-warning me-2"
        onclick="showSection('updateSection')">

            Update Item

        </button>

        <button
        class="btn btn-danger"
        onclick="showSection('deleteSection')">

            Delete Item

        </button>

    </div>

    <!-- ADD SECTION -->

    <div id="addSection" class="card">

        <div class="card-body">

            <h3 class="mb-4">
                Add New Item
            </h3>

            <form
            method="POST"
            action="/owner/menu/add">

                <input
                type="text"
                name="name"
                placeholder="Food Name"
                class="form-control mb-3"
                required>

                <input
                type="text"
                name="image"
                placeholder="Image URL"
                class="form-control mb-3"
                required>

                <input
                type="number"
                name="price"
                placeholder="Price"
                class="form-control mb-3"
                required>

                <input
                type="text"
                name="Type"
                placeholder="Veg / Non-Veg"
                class="form-control mb-3"
                required>

                <select
                name="Cheese"
                class="form-select mb-3">

                    <option value="true">
                        Cheese
                    </option>

                    <option value="false">
                        No Cheese
                    </option>

                </select>

                <button
                type="submit"
                class="btn btn-success">

                    Add Item

                </button>

            </form>

        </div>

    </div>

    <!-- UPDATE SECTION -->

    <div id="updateSection" style="display:none;">

        <% menus.forEach(menu => { %>

        <div class="card mb-3">

            <div class="card-body">

                <h5 class="mb-3">
                    <%= menu.Name %>
                </h5>

                <form
                method="POST"
                action="/owner/menu/update/<%= menu._id %>">

                    <input
                    type="text"
                    name="name"
                    value="<%= menu.Name %>"
                    class="form-control mb-2">

                    <input
                    type="text"
                    name="image"
                    value="<%= menu.image %>"
                    class="form-control mb-2">

                    <input
                    type="number"
                    name="price"
                    value="<%= menu.price %>"
                    class="form-control mb-2">

                    <input
                    type="text"
                    name="Type"
                    value="<%= menu.Type %>"
                    class="form-control mb-2">

                    <select
                    name="Cheese"
                    class="form-select mb-3">

                        <option
                        value="true"
                        <%= menu.Cheese ? "selected" : "" %>>
                            Cheese
                        </option>

                        <option
                        value="false"
                        <%= !menu.Cheese ? "selected" : "" %>>
                            No Cheese
                        </option>

                    </select>

                    <button
                    type="submit"
                    class="btn btn-warning">

                        Update Item

                    </button>

                </form>

            </div>

        </div>

        <% }) %>

    </div>

    <!-- DELETE SECTION -->

    <div id="deleteSection" style="display:none;">

        <% menus.forEach(menu => { %>

        <div class="card mb-3">

            <div class="card-body d-flex justify-content-between align-items-center">

                <div>

                    <h5>
                        <%= menu.Name %>
                    </h5>

                    <p class="mb-0">
                        ₹<%= menu.price %>
                    </p>

                </div>

                <form
                method="POST"
                action="/owner/menu/delete/<%= menu._id %>">

                    <button
                    type="submit"
                    class="btn btn-danger">

                        Delete

                    </button>

                </form>

            </div>

        </div>

        <% }) %>

    </div>

</div>

<script>

function showSection(sectionId)
{
    document.getElementById("addSection").style.display = "none";
    document.getElementById("updateSection").style.display = "none";
    document.getElementById("deleteSection").style.display = "none";

    document.getElementById(sectionId).style.display = "block";
}

</script>

<%- include("partials/script") %>

</body>
</html>