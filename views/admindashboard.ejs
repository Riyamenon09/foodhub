<!DOCTYPE html>
<html>

<head>
    <%- include("partials/head") %>
</head>

<body>

<%- include("partials/nav") %>

<div class="container mt-5">

    <h1 class="mb-4">
        Admin Dashboard
    </h1>

    <!-- Navigation Buttons -->

    <div class="mb-4">

        <button
        class="btn btn-success me-2"
        onclick="showSection('add')">

            Add Restaurant

        </button>

        <button
        class="btn btn-warning me-2"
        onclick="showSection('update')">

            Update Restaurant

        </button>

        <button
        class="btn btn-danger"
        onclick="showSection('delete')">

            Delete Restaurant

        </button>

    </div>

    <!-- ADD SECTION -->

    <div id="addSection">

        <div class="card">

            <div class="card-body">

                <h3 class="mb-3">
                    Add Restaurant
                </h3>

                <form
                method="POST"
                action="/admin/restaurant/add">

                    <input
                    type="text"
                    name="name"
                    placeholder="Restaurant Name"
                    class="form-control mb-2"
                    required>

                    <input
                    type="text"
                    name="image"
                    placeholder="Image URL"
                    class="form-control mb-2"
                    required>

                    <input
                    type="text"
                    name="category"
                    placeholder="Category"
                    class="form-control mb-2"
                    required>

                    <input
                    type="text"
                    name="rating"
                    placeholder="Rating"
                    class="form-control mb-2"
                    required>

                    <input
                    type="text"
                    name="address"
                    placeholder="Address"
                    class="form-control mb-2"
                    required>

                    <input
                    type="text"
                    name="deliverytime"
                    placeholder="Delivery Time"
                    class="form-control mb-2"
                    required>

                    <textarea
                    name="description"
                    placeholder="Description"
                    class="form-control mb-3"
                    required></textarea>

                    <button
                    class="btn btn-success">

                        Add Restaurant

                    </button>

                </form>

            </div>

        </div>

    </div>

    <!-- UPDATE SECTION -->

    <div
    id="updateSection"
    style="display:none;">

        <h3 class="mb-3">
            Update Restaurants
        </h3>

        <% restaurants.forEach(restaurant=>{ %>

        <div class="card mb-3">

            <div class="card-body">

                <form
                method="POST"
                action="/admin/restaurant/update/<%= restaurant._id %>">

                    <input
                    type="text"
                    name="name"
                    value="<%= restaurant.name %>"
                    class="form-control mb-2">

                    <input
                    type="text"
                    name="image"
                    value="<%= restaurant.image %>"
                    class="form-control mb-2">

                    <input
                    type="text"
                    name="category"
                    value="<%= restaurant.category %>"
                    class="form-control mb-2">

                    <input
                    type="text"
                    name="rating"
                    value="<%= restaurant.rating %>"
                    class="form-control mb-2">

                    <input
                    type="text"
                    name="address"
                    value="<%= restaurant.address %>"
                    class="form-control mb-2">

                    <input
                    type="text"
                    name="deliverytime"
                    value="<%= restaurant.deliverytime %>"
                    class="form-control mb-2">

                    <textarea
                    name="description"
                    class="form-control mb-3"><%= restaurant.description %></textarea>

                    <button
                    class="btn btn-warning">

                        Update

                    </button>

                </form>

            </div>

        </div>

        <% }) %>

    </div>

    <!-- DELETE SECTION -->

    <div
    id="deleteSection"
    style="display:none;">

        <h3 class="mb-3">
            Delete Restaurants
        </h3>

        <% restaurants.forEach(restaurant=>{ %>

        <div class="card mb-3">

            <div class="card-body d-flex justify-content-between align-items-center">

                <div>

                    <h5>
                        <%= restaurant.name %>
                    </h5>

                    <p class="mb-0">
                        <%= restaurant.category %>
                    </p>

                </div>

                <form
                method="POST"
                action="/admin/restaurant/delete/<%= restaurant._id %>">

                    <button
                    class="btn btn-danger">

                        Delete

                    </button>

                </form>

            </div>

        </div>

        <% }) %>

    </div>

</div>

<script>

function showSection(section)
{
    document.getElementById("addSection").style.display = "none";
    document.getElementById("updateSection").style.display = "none";
    document.getElementById("deleteSection").style.display = "none";

    if(section === "add")
    {
        document.getElementById("addSection").style.display = "block";
    }

    if(section === "update")
    {
        document.getElementById("updateSection").style.display = "block";
    }

    if(section === "delete")
    {
        document.getElementById("deleteSection").style.display = "block";
    }
}

</script>

<%- include("partials/script") %>

</body>

</html>