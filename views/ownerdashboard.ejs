<!DOCTYPE html>
<html>

<head>
    <%- include("partials/head") %>
</head>

<body>

    <%- include("partials/ownernav") %>
    
    <div class="container mt-5">

        <h1 class="mb-4">
            Owner Dashboard
        </h1>

        <% if(orders.length === 0){ %>

            <div class="alert alert-info">
                No Orders Yet
            </div>

        <% } else { %>

            <% orders.forEach(order => { %>

                <div class="card shadow-sm mb-4">

                    <div class="card-body">

                        <h5>
                            Customer:
                            <%= order.address.fullName %>
                        </h5>

                        <p>
                            Phone:
                            <%= order.address.phone %>
                        </p>

                        <p>
                            Total:
                            ₹<%= order.totalAmount %>
                        </p>

                        <p>
                            Status:
                            <span class="badge bg-warning">
                                <%= order.status %>
                            </span>
                        </p>


                        <div class="mt-3">

                            <form
                                method="POST"
                                action="/owner/status/<%= order._id %>"
                                class="d-flex gap-2">

                                <select
                                    name="status"
                                    class="form-select w-auto">

                                    <option value="Placed">
                                        Placed
                                    </option>

                                    <option value="Preparing">
                                        Preparing
                                    </option>

                                    <option value="Out For Delivery">
                                        Out For Delivery
                                    </option>

                                    <option value="Delivered">
                                        Delivered
                                    </option>

                                </select>

                                <button
                                    type="submit"
                                    class="btn btn-primary">

                                    Update

                                </button>

                            </form>

                        </div>

                        <hr>

                        <h6>
                            Ordered Items
                        </h6>

                        <% order.items.forEach(item => { %>

                            <div class="d-flex justify-content-between">

                                <span>
                                    <%= item.menuId.Name %> x <%= item.quantity %>
                                </span>

                                <span>
                                    ₹<%= item.price * item.quantity %>
                                </span>

                            </div>

                        <% }) %>

                    </div>

                </div>

            <% }) %>

        <% } %>

    </div>

    <%- include("partials/script") %>

</body>

</html>