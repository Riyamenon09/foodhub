<!DOCTYPE html>
<html>
<head>
    <%- include("partials/head") %>
</head>
<body>

<%- include("partials/nav") %>

<div class="container mt-5">

    <h1 class="mb-4">
        My Order
    </h1>

    <% if(!order){ %>

        <div class="alert alert-info">
            No Orders Yet
        </div>

    <% } else { %>

        <div class="card shadow-sm">

            <div class="card-body">

                <h5 class="fw-bold">
                    Order ID:
                    <%= order._id %>
                </h5>

                <p class="text-muted">
                    <%= order.createdAt.toDateString() %>
                </p>

                <hr>

                <h6>
                    Ordered Items
                </h6>

                <% order.items.forEach(item => { %>

                    <div class="d-flex justify-content-between">

                        <span>
                            <%= item.menuId.Name %>
                            x
                            <%= item.quantity %>
                        </span>

                        <span>
                            ₹<%= item.price * item.quantity %>
                        </span>

                    </div>

                <% }) %>

                <hr>

                <p>
                    <strong>Total Amount:</strong>
                    ₹<%= order.totalAmount %>
                </p>

                <p>
                    <strong>Payment Method:</strong>
                    <%= order.paymentMethod %>
                </p>

                <p>
                    <strong>Status:</strong>

                    <span class="badge bg-success">
                        <%= order.status %>
                    </span>
                </p>

                <hr>

                <h6>
                    Order Tracking
                </h6>

                <div class="d-flex justify-content-between text-center">

                    <div>
                        <div class="<%= ['Placed','Preparing','Out For Delivery','Delivered'].includes(order.status) ? 'text-success fw-bold fs-4' : 'fs-4' %>">
                            ●
                        </div>
                        <small>Placed</small>
                    </div>

                    <div>
                        <div class="<%= ['Preparing','Out For Delivery','Delivered'].includes(order.status) ? 'text-success fw-bold fs-4' : 'fs-4' %>">
                            ●
                        </div>
                        <small>Preparing</small>
                    </div>

                    <div>
                        <div class="<%= ['Out For Delivery','Delivered'].includes(order.status) ? 'text-success fw-bold fs-4' : 'fs-4' %>">
                            ●
                        </div>
                        <small>Out For Delivery</small>
                    </div>

                    <div>
                        <div class="<%= order.status === 'Delivered' ? 'text-success fw-bold fs-4' : 'fs-4' %>">
                            ●
                        </div>
                        <small>Delivered</small>
                    </div>

                </div>

            </div>

        </div>

    <% } %>

</div>

<%- include("partials/script") %>

</body>
</html>