<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include("partials/head") %>
    <title>Document</title>
</head>
<style>
    .heroimage img
    {
        height:600px;
        object-fit: cover;
    }
    .category-img{
    width:200px;
    height:200px;
    border-radius:50%;
    object-fit:cover;
    border:3px solid #fc8019;
    cursor:pointer;
    transition:0.3s;
}

.category-img:hover{
    transform:scale(1.05);
}
</style>
<body>
    <%- include("partials/nav") %>
    <section class="heroimage">
        <img class="image-fluid w-100" src="https://images.unsplash.com/photo-1604382354936-07c5d9983bd3?fm=jpg&q=60&w=3000&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8NHx8cGl6emElMjBpbWFnZXN8ZW58MHx8MHx8fDA%3D" alt="heroimage">
    </section>
    
    <section class="container my-5">

    <h1 class="text-center mb-5">Food Category</h1>

    <div class="row text-center">

        <% categories.forEach(element => { %>

            <div class="col-md-2">

                <a href="/restaurant/<%= element.name %>">
                    <img
                    src="<%= element.image %>"
                    class="category-img"
                    alt="<%= element.name %>">

        
                </a>
                <h5 class="mt-3">
                    <%= element.name %>
                </h5>

            </div>

        <% }) %>

    </div>

</section>
<section class="container mt-5">
<div class="row g-4">
    <div class="col-md-6">
         <div class="p-4 bg-warning-subtle rounded mb-4">
                <h4>🍽️ 100% Hygienic Food</h4>
                <p>Certified restaurants with strict hygiene standards.</p>
            </div>

            <div class="p-4 bg-success-subtle rounded mb-4">
                <h4>⚡ Fast Delivery</h4>
                <p>Get your food delivered in under 30 minutes.</p>
            </div>

            <div class="p-4 bg-info-subtle rounded">
                <h4>🥗 Fresh Ingredients</h4>
                <p>Only fresh and high-quality ingredients are used.</p>
            </div>

        </div>
    
     <div class="col-md-6">

            <div class="p-4 bg-danger-subtle rounded mb-4">
                <h4>🎉 Exciting Offers</h4>
                <p>Daily discounts and cashback on orders.</p>
            </div>

            <div class="p-4 bg-primary-subtle rounded mb-4">
                <h4>⭐ Top Rated Restaurants</h4>
                <p>We partner only with highly rated restaurants.</p>
            </div>

            <div class="p-4 bg-secondary-subtle rounded">
                <h4>🔒 Secure Payments</h4>
                <p>100% secure online payments and transactions.</p>
            </div>

        </div>
</div>


</div>


</section>
<%- include("partials/footer") %>
<%- include("partials/script") %>
</body>
</html>