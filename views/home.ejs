<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include("partials/head") %>
    <title>Home Page</title>
    <style>
.heroimage img
{
    width:100%;
    height:600px;
    object-fit:cover;
}

.category-img
{
    width:150px;
    height:150px;
    border-radius:50%;
    object-fit:cover;
    border:3px solid #fc8019;
    cursor:pointer;
    transition:0.3s;
}

.category-img:hover
{
    transform:scale(1.05);
}

.feature-card
{
    height:100%;
}

@media(max-width:768px)
{
    .heroimage img
    {
        height:350px;
    }

    .category-img
    {
        width:120px;
        height:120px;
    }
}

@media(max-width:576px)
{
    .heroimage img
    {
        height:250px;
    }

    .category-img
    {
        width:100px;
        height:100px;
    }

    h5
    {
        font-size:1rem;
    }

    .feature-card h4
    {
        font-size:1rem;
    }

    .feature-card p
    {
        font-size:0.85rem;
    }
}
body
{
    background-color:#f8f9fa;
}
</style>

</head>

<body>

<%- include("partials/nav") %>

<section class="heroimage">

<img
class="img-fluid w-100"
src="https://images.unsplash.com/photo-1604382354936-07c5d9983bd3?fm=jpg&q=60&w=3000&auto=format&fit=crop"
alt="heroimage">

</section>

<!-- Categories -->

<section class="container my-5">

<h1 class="text-center mb-5">
Food Category
</h1>

<div class="row text-center justify-content-center">

<% categories.forEach(element => { %>

<div class="col-6 col-sm-4 col-md-3 col-lg-2 mb-4">

<a href="/restaurant/<%= element.name %>">

<img
src="<%= element.image %>"
class="category-img"
alt="<%= element.name %>">

</a>

<h5 class="mt-3">
<%= element.name %>
</h5>

</div>

<% }) %>

</div>

</section>

<!-- Features -->

<section class="container my-5">

<div class="row g-4">

<div class="col-6 col-md-6">

<div class="p-4 bg-warning-subtle rounded feature-card">
<h4> <i class="fa-solid fa-utensils" style="color: rgb(90, 90, 86);"></i> 100% Hygienic Food</h4>
<p>Certified restaurants with strict hygiene standards.</p>
</div>

</div>

<div class="col-6 col-md-6">

<div class="p-4 bg-danger-subtle rounded feature-card">
<h4><i class="fa-solid fa-gift" style="color: rgb(237, 44, 44);"></i> Exciting Offers</h4>
<p>Daily discounts and cashback on orders.</p>
</div>

</div>

<div class="col-6 col-md-6">

<div class="p-4 bg-success-subtle rounded feature-card">
<h4><i class="fa-solid fa-bolt" style="color: rgb(237, 162, 10);"></i> Fast Delivery</h4>
<p>Get your food delivered in under 30 minutes.</p>
</div>

</div>

<div class="col-6 col-md-6">

<div class="p-4 bg-primary-subtle rounded feature-card">
<h4><i class="fa-solid fa-star" style="color: rgb(255, 212, 59);"></i> Top Rated Restaurants</h4>
<p>We partner only with highly rated restaurants.</p>
</div>

</div>

<div class="col-6 col-md-6">

<div class="p-4 bg-info-subtle rounded feature-card">
<h4><i class="fa-solid fa-bowl-rice" style="color: rgb(114, 135, 234);"></i> Fresh Ingredients</h4>
<p>Only fresh and high-quality ingredients are used.</p>
</div>

</div>

<div class="col-6 col-md-6">

<div class="p-4 bg-secondary-subtle rounded feature-card">
<h4><i class="fa-solid fa-lock" style="color: rgb(58, 55, 55);"></i> Secure Payments</h4>
<p>100% secure online payments and transactions.</p>
</div>

</div>

</div>

</section>

<%- include("partials/footer") %>
<%- include("partials/script") %>

</body>