<!DOCTYPE html>
<html>

<head>
    <%- include("partials/head") %>
</head>
<style>
    body
{
    background:#f8f9fa;
}

.card
{
    border:none;
    border-radius:20px;
    overflow:hidden;
    transition:0.3s;
}

.card:hover
{
    transform:translateY(-3px);
    box-shadow:0 10px 25px rgba(0,0,0,0.12);
}

.form-control
{
    border-radius:10px;
    padding:12px;
}

.form-control:focus
{
    box-shadow:none;
    border-color:#fc8019;
}

.summary-item
{
    margin-bottom:10px;
}

.place-order-btn
{
    border-radius:12px;
    padding:12px;
    font-size:18px;
    font-weight:600;
}
</style>
<body>

    <%- include("partials/nav") %>

        <div class="container my-5">

            <h1 class="mb-1">
                Checkout
            </h1>

            <form method="POST" action="/checkout/placeorder">
                <div class="row">

                <!-- Left -->

                <div class="col-md-7">

                    <div class="card p-4 shadow-sm">

                        <h3 class="fw-bold mb-4">
                            Delivery Address
                        </h3>

                        <input type="text" class="form-control mb-3" name="fullName" placeholder="Full Name" required minlength="3">

                        <input type="tel" class="form-control mb-3" name="phone" placeholder="Phone Number" required pattern="[0-9]{10}" title="Enter 10 digit phone number">

                       <input type="text" class="form-control mb-3" name="houseNo" placeholder="House No" required>

                        <input type="text" class="form-control mb-3" name="area" placeholder="Area" required>

                        <input type="text" class="form-control mb-3" name="city" placeholder="City" required>

                        <input type="text" class="form-control mb-3" name="pincode" placeholder="Pincode" required pattern="[0-9]{6}" title="Enter 6 digit pincode">

                    </div>

                    <div class="card p-4 shadow-sm mt-4 mb-4">

                        <h3 class="fw-bold mb-4">
                            Payment Method
                        </h3>

                        <div class="form-check">

                            <input class="form-check-input" type="radio" name="paymentMethod" value="COD" checked>

                            <label>
                                Cash On Delivery
                            </label>

                        </div>

                        <div class="form-check">

                            <input class="form-check-input" type="radio" name="paymentMethod" value="UPI">

                            <label>
                                UPI
                            </label>

                        </div>

                        <div class="form-check">

                            <input class="form-check-input" type="radio" name="paymentMethod" value="CARD">

                            <label>
                                Credit / Debit Card
                            </label>

                        </div>

                    </div>

                </div>

            </form>
                <!-- Right -->

                <div class="col-md-5">

                    <div class="card p-4 shadow-sm">

                        <h3 class="fw-bold mb-4">
                            Order Summary
                        </h3>

                        <% cart.items.forEach(item=>{ %>

                            <div class="d-flex justify-content-between">

                                <span>

                                    <%= item.menuId.Name %>

                                        x

                                        <%= item.quantity %>

                                </span>

                                <span>

                                    ₹<%= total %>

                                </span>

                            </div>

                            <% }) %>

                                <hr>

                                <div class="d-flex justify-content-between">

                                    <span>
                                        Subtotal
                                    </span>

                                    <span>
                                        ₹<%= total %>
                                    </span>

                                </div>

                                <div class="d-flex justify-content-between">

                                    <span>
                                        Delivery
                                    </span>

                                    <span>
                                        ₹40
                                    </span>

                                </div>

                                <div class="d-flex justify-content-between">

                                    <span>
                                        GST
                                    </span>

                                    <span>
                                        ₹20
                                    </span>

                                </div>

                                <hr>

                                <div class="d-flex justify-content-between fw-bold">

                                    <span>
                                        Grand Total
                                    </span>

                                    <span>
                                        ₹<%= total+40+20 %>
                                    </span>

                                </div>

                                <button type="submit" class="btn btn-success mt-4 w-100">

                                    Place Order

                                </button>

                    </div>

                </div>

            </div>

        </div>

        <%- include("partials/script") %>
<script>

document.querySelector("form").addEventListener("submit",function(e)
{
    const phone=document.querySelector("[name='phone']").value;
    const pincode=document.querySelector("[name='pincode']").value;

    if(phone.length!==10)
    {
        alert("Phone number must be 10 digits");
        e.preventDefault();
        return;
    }

    if(pincode.length!==6)
    {
        alert("Pincode must be 6 digits");
        e.preventDefault();
    }
});

</script>
</body>

</html>