<!DOCTYPE html>
<html>

<head>

    <%- include("partials/head") %>

    <style>

        body
        {
            background:#f8f9fa;
        }

        .cart-img
        {
            width:100px;
            height:100px;
            object-fit:cover;
            border-radius:12px;
        }

        .cart-card
        {
            border:none;
            border-radius:15px;
            overflow:hidden;
            transition:0.3s;
        }

        .cart-card:hover
        {
            transform:translateY(-3px);
            box-shadow:0 8px 20px rgba(0,0,0,0.1);
        }

        .quantity-btn
        {
            width:35px;
            height:35px;
            padding:0;
            font-weight:bold;
        }

        .checkout-btn
        {
            width:50%;
        }

        @media(min-width:768px)
        {
            .checkout-btn
            {
                width:auto;
            }

            .cart-img
            {
                width:130px;
                height:130px;
            }
        }

    </style>

</head>

<body>

<%- include("partials/nav") %>

<div class="container mt-5">

    <% 
        let totalAmount = 0;

        if(cart)
        {
            cart.items.forEach(item =>
            {
                totalAmount += item.menuId.price * item.quantity;
            });
        }
    %>

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">

        <h1 class="mb-3 mb-md-0">
            My Cart
        </h1>

        <% if(cart && cart.items.length > 0){ %>


        <% } %>

    </div>

    <% if(!cart || cart.items.length===0){ %>

        <div class="text-center mt-5">

            <h3>
                Your cart is empty 🛒
            </h3>

        </div>

    <% } else { %>

        <% cart.items.forEach(item=>{ %>

        <div class="card cart-card shadow-sm mb-3">

            <div class="card-body">

                <div class="row align-items-center">

                    <div class="col-4 col-md-3 text-center">

                        <img
                        src="<%= item.menuId.image %>"
                        class="cart-img">

                    </div>

                    <div class="col-8 col-md-9">

                        <h4 class="mb-1">

                            <%= item.menuId.Name %>

                        </h4>

                        <p class="text-muted mb-1">

                            <i class="bi bi-shop"></i>

                            <%= item.menuId.restaurantId.name %>

                        </p>

                        <h5 class="text-success mb-3">

                            ₹<%= item.menuId.price %>

                        </h5>

                        <div class="d-flex align-items-center gap-2">

                            <form
                            method="POST"
                            action="/cart/decrease/<%= item.menuId._id %>">

                                <button
                                class="btn btn-danger quantity-btn">

                                    -

                                </button>

                            </form>

                            <span class="fw-bold fs-5">

                                <%= item.quantity %>

                            </span>

                            <form
                            method="POST"
                            action="/cart/increase/<%= item.menuId._id %>">

                                <button
                                class="btn btn-success quantity-btn">

                                    +

                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            </div>
            

        </div>
        
        <% }) %>

    <% } %>
<div class="text-end">
            <a
            href="/checkout"
            class="btn btn-success checkout-btn">

                Checkout →

            </a>

        </div>

</div>

<%- include("partials/footer") %>
<%- include("partials/script") %>

</body>

</html>